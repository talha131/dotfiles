#!/usr/bin/env bash
# my-secure-input — report (and optionally alert on) macOS Secure Input state.
#
# macOS "Secure Input" (Secure Keyboard Entry) blocks ALL global keystroke
# monitoring: text expanders (Raycast snippets), clipboard/hotkey managers
# (PasteNow), and third-party input methods (Keyman) all go blind until it is
# released. Apps enable it when a password field is *focused* (you need not
# type anything), and some — notably Electron apps like Obsidian — leak it and
# leave it stuck. Force-killing such an app orphans the lock onto a dead PID,
# which then only a logout/reboot can clear.
#
# Usage:
#   my-secure-input            Show who currently holds Secure Input.
#   my-secure-input --notify   Post a macOS notification if a non-allowlisted
#                              app holds it (used by the launchd watchdog).
#                              Silent when all is well; debounced to once per
#                              episode.

set -u

# Apps that may legitimately hold Secure Input — don't warn about these.
#   loginwindow — during screen lock.
#   iTerm2 / Terminal — if you deliberately enable Secure Keyboard Entry.
# Adjust to taste.
ALLOWLIST="loginwindow iTerm2 Terminal"

# Ephemeral state for debouncing notifications (one alert per holding PID).
STATE_FILE="${TMPDIR:-/tmp}/my-secure-input.lastpid"

secure_input_pid() {
    ioreg -l -w 0 \
        | sed -n 's/.*"kCGSSessionSecureInputPID"=\([0-9]*\).*/\1/p' \
        | head -1
}

# Basename of a PID's executable; empty if the PID is dead.
proc_name() {
    ps -p "$1" -o comm= 2>/dev/null | sed 's#.*/##'
}

notify() {
    osascript -e "display notification \"$2\" with title \"$1\"" >/dev/null 2>&1 || true
}

mode="${1:-report}"
pid="$(secure_input_pid)"

# --- Secure Input is OFF -------------------------------------------------------
if [ -z "$pid" ] || [ "$pid" = "0" ]; then
    rm -f "$STATE_FILE" 2>/dev/null || true
    [ "$mode" = "--notify" ] && exit 0
    echo "🟢 Secure Input is OFF."
    exit 0
fi

name="$(proc_name "$pid")"

# --- Held by a live, allowlisted app ------------------------------------------
if [ -n "$name" ]; then
    for a in $ALLOWLIST; do
        if [ "$name" = "$a" ]; then
            rm -f "$STATE_FILE" 2>/dev/null || true
            [ "$mode" = "--notify" ] && exit 0
            echo "🟢 Secure Input held by allowlisted app: $name (pid $pid)."
            exit 0
        fi
    done
fi

# --- Problem: non-allowlisted app, or a dead PID (orphaned/stuck) --------------
if [ -z "$name" ]; then
    label="Secure Input STUCK"
    detail="Held by dead PID $pid — snippets, hotkeys & input methods are blind. Log out/in or reboot to clear."
else
    label="Secure Input held by $name"
    detail="$name (pid $pid) is blocking snippets, hotkeys & input methods. Cleanly quit it (⌘Q) — do NOT force-kill."
fi

if [ "$mode" = "--notify" ]; then
    last=""
    [ -f "$STATE_FILE" ] && last="$(cat "$STATE_FILE" 2>/dev/null || true)"
    if [ "$last" != "$pid" ]; then
        notify "$label" "$detail"
        printf '%s' "$pid" > "$STATE_FILE" 2>/dev/null || true
    fi
    exit 0
fi

echo "🔴 $label"
echo "   $detail"
exit 0
