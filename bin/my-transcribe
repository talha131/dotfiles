#!/usr/bin/env -S uv run --script
# /// script
# dependencies = [
#   "google-genai",
# ]
# ///

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

WHISPER_MODEL = os.path.expanduser("~/.local/share/whisper-cpp/ggml-large-v3-turbo.bin")

HELP_TEXT = """\
Transcribe audio files to text.

The transcription is saved as a .txt file alongside the original audio file.
For example, "lecture.mp3" produces "lecture.txt" in the same directory.

--- Gemini engine (default) ---

Uses Google's Gemini API. Fast and high quality, but requires internet.

Setup:
  Fish shell:  set -gx GEMINI_API_KEY 'your_key'
  Bash/Zsh:    export GEMINI_API_KEY='your_key'

Language: free-form string via --language (e.g. "English", "a mix of Urdu
  and English"). Defaults to a mix of Urdu and English.

--- Whisper engine (local) ---

Uses whisper.cpp locally. Runs offline, no API key needed.

Setup:
  1. brew install whisper-cpp ffmpeg
  2. Download a GGML model:
     curl -L -o ~/.local/share/whisper-cpp/ggml-large-v3-turbo.bin \\
       https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3-turbo.bin
     Other models: https://huggingface.co/ggerganov/whisper.cpp/tree/main

Language: language code via --language (e.g. "en", "ur", "auto").
  Defaults to auto-detect. Codes: https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes
"""


def build_prompt(language):
    if language:
        return (
            f"Transcribe this audio exactly as spoken. The audio is in {language}. "
            "Keep the transcription comprehensive, including classroom management and anecdotes. "
            "Do not use timestamps. Use the appropriate script for each language."
        )
    return (
        "Transcribe this audio exactly as spoken. The lecture is in a mix of Urdu and English. "
        "Keep the transcription comprehensive, including classroom management and anecdotes. "
        "Do not use timestamps. Use Urdu script for Urdu words and English script for English terms."
    )


def transcribe_gemini(file_path, language=None):
    from google import genai

    api_key = os.getenv("GEMINI_API_KEY")
    if not api_key:
        print("Error: Please set the GEMINI_API_KEY environment variable.")
        sys.exit(1)

    client = genai.Client(api_key=api_key)

    print(f"Uploading {file_path.name}...")
    audio_file = client.files.upload(file=str(file_path))

    prompt = build_prompt(language)
    lang_display = language if language else "Urdu/English mix"
    print(f"Transcribing with Gemini 3 Flash ({lang_display})... (this may take a minute)")

    response = client.models.generate_content(
        model="gemini-3-flash-preview",
        contents=[prompt, audio_file],
    )

    # Show cost estimate
    usage = response.usage_metadata
    if usage:
        audio_tokens = 0
        text_tokens = 0
        if hasattr(usage, "prompt_tokens_details") and usage.prompt_tokens_details:
            for detail in usage.prompt_tokens_details:
                if detail.modality.name == "AUDIO":
                    audio_tokens = detail.token_count
                else:
                    text_tokens += detail.token_count
        else:
            # Fallback: treat all input as audio (overestimates slightly)
            audio_tokens = usage.prompt_token_count

        output_tokens = usage.candidates_token_count or 0
        audio_seconds = audio_tokens / 32
        minutes = int(audio_seconds) // 60
        seconds = int(audio_seconds) % 60

        # Pricing per 1M tokens (Gemini Flash standard tier)
        audio_cost = audio_tokens * 0.70 / 1_000_000
        text_cost = text_tokens * 0.10 / 1_000_000
        output_cost = output_tokens * 0.40 / 1_000_000
        total_cost = audio_cost + text_cost + output_cost

        print(f"Audio: ~{minutes}m {seconds}s | Estimated cost: ~${total_cost:.4f}")

    return response.text


def transcribe_whisper(file_path, language=None):
    if not shutil.which("whisper-cli"):
        print("Error: whisper-cli not found. Install with: brew install whisper-cpp")
        sys.exit(1)

    if not shutil.which("ffmpeg"):
        print("Error: ffmpeg not found. Install with: brew install ffmpeg")
        sys.exit(1)

    if not Path(WHISPER_MODEL).exists():
        print(f"Error: Whisper model not found at {WHISPER_MODEL}")
        print("Download from: https://huggingface.co/ggerganov/whisper.cpp/tree/main")
        sys.exit(1)

    # whisper-cpp only supports WAV (16kHz mono), so convert first
    wav_file = None
    try:
        wav_file = tempfile.NamedTemporaryFile(suffix=".wav", delete=False)
        wav_file.close()

        print(f"Converting {file_path.name} to WAV...")
        subprocess.run(
            ["ffmpeg", "-i", str(file_path), "-ar", "16000", "-ac", "1", "-y", wav_file.name],
            capture_output=True, check=True,
        )

        lang_code = language if language else "auto"
        lang_display = language if language else "auto-detect"
        print(f"Transcribing with whisper.cpp ({lang_display})... (this may take a while)")

        # -mc 0 disables cross-window context carry-over (prevents the
        # previous chunk's hallucinations from feeding into the next chunk
        # and locking in repetition cascades). --suppress-nst suppresses
        # non-speech tokens that leak from YouTube training data
        # (e.g. "موسیقی" / "music" tags). Both are essential on long-form
        # non-Latin audio; without them whisper collapses into single-token
        # spam within ~30 seconds.
        cmd = [
            "whisper-cli",
            "-m", WHISPER_MODEL,
            "-l", lang_code,
            "-mc", "0",
            "--suppress-nst",
            "--no-timestamps",
            wav_file.name,
        ]
        # Don't use text=True — whisper-cli's byte-fallback tokenizer can emit
        # partial multi-byte UTF-8 sequences in both stdout (the transcription)
        # and stderr (progress logs), especially on Urdu/Arabic. Strict UTF-8
        # decoding would crash here, so capture raw bytes and clean them
        # manually below. Mirrors the fix in my-youtube-subtitles (8e9c6ca).
        result = subprocess.run(cmd, capture_output=True)

        if result.returncode != 0:
            stderr_text = result.stderr.decode("utf-8", errors="replace")
            print(f"Error from whisper-cli:\n{stderr_text}")
            sys.exit(1)

        # Walk the stdout bytes keeping only complete 1-4 byte UTF-8 sequences.
        # This silently drops orphaned leading/continuation bytes from whisper's
        # byte-fallback tokens, preserving maximum valid text without inserting
        # replacement characters.
        raw = result.stdout
        cleaned = bytearray()
        i = 0
        while i < len(raw):
            b = raw[i]
            if b < 0x80:
                cleaned.append(b)
                i += 1
            elif b < 0xC0:
                # stray continuation byte — skip
                i += 1
            elif b < 0xE0:
                if i + 1 < len(raw) and 0x80 <= raw[i + 1] < 0xC0:
                    cleaned.extend(raw[i:i + 2])
                i += 2
            elif b < 0xF0:
                if i + 2 < len(raw) and all(0x80 <= raw[i + j] < 0xC0 for j in (1, 2)):
                    cleaned.extend(raw[i:i + 3])
                i += 3
            else:
                if i + 3 < len(raw) and all(0x80 <= raw[i + j] < 0xC0 for j in (1, 2, 3)):
                    cleaned.extend(raw[i:i + 4])
                i += 4
        return cleaned.decode("utf-8").strip()

    finally:
        if wav_file and Path(wav_file.name).exists():
            Path(wav_file.name).unlink()


def main():
    parser = argparse.ArgumentParser(
        prog="my-transcribe",
        description=HELP_TEXT,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("audio_file", help="Path to the audio file to transcribe")
    parser.add_argument(
        "--language", "-l",
        help="Language of the audio (see engine sections above for format and defaults)",
    )
    parser.add_argument(
        "--engine", "-e",
        choices=["gemini", "whisper"],
        default="whisper",
        help="Transcription engine to use (default: whisper)",
    )
    args = parser.parse_args()

    file_path = Path(args.audio_file)
    if not file_path.exists():
        print(f"Error: File '{file_path}' not found.")
        sys.exit(1)

    try:
        if args.engine == "whisper":
            text = transcribe_whisper(file_path, language=args.language)
        else:
            text = transcribe_gemini(file_path, language=args.language)

        output_file_path = file_path.with_suffix('.txt')
        with open(output_file_path, "w", encoding="utf-8") as f:
            f.write(text)

        print("\n--- SUCCESS ---")
        print(f"Transcription saved to: {output_file_path.name}")

    except Exception as e:
        print(f"An error occurred during transcription: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
