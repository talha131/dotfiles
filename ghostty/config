# Ghostty config — also read by cmux's embedded Ghostty.
# cmux reads this file for terminal rendering (font, theme, transparency, …).
# Apply changes live with: cmux reload-config

# Font
font-family = MesloLGL Nerd Font Mono
font-size = 12
# Thicken strokes — Meslo renders too thin at 12pt otherwise.
font-thicken = true

# Appearance
theme = light:Breadog,dark:Breadog
